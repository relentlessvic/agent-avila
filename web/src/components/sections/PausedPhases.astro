---
import type { DashboardData } from '../../lib/types';
import Section from '../Section.astro';
import Card from '../Card.astro';
import { SECTION_IDS } from '../../lib/constants';

interface Props {
  data: DashboardData;
}
const { data } = Astro.props;
---
{data.pausedPhases.length > 0 && (
  <Section id={SECTION_IDS.pausedPhases} title="Paused Phases" icon="pause" count={data.pausedPhases.length}>
    <Card class="space-y-3">
      {data.pausedPhases.map(p => (
        <div class="border-l-2 border-cyber-amber/50 pl-4 py-1">
          <p class="font-mono text-sm text-slate-200 break-words">{p.name}</p>
          <p class="text-xs text-slate-500 mt-1 leading-relaxed">{p.note}</p>
        </div>
      ))}
    </Card>
  </Section>
)}
