---
import type { DashboardData } from '../../lib/types';
import Section from '../Section.astro';
import Card from '../Card.astro';
import SHAChip from '../SHAChip.astro';
import { SECTION_IDS } from '../../lib/constants';

interface Props {
  data: DashboardData;
}
const { data } = Astro.props;

// Friendlier label per anchor label (presentation-only).
function friendlyAnchorLabel(label: string): string {
  const key = (label || '').toLowerCase();
  if (key.includes('parent')) return 'Parent project';
  if (key.includes('relay')) return 'Messenger project';
  return label;
}
---
<Section id={SECTION_IDS.repoAnchors} title="Code checkpoints">
  <Card tier="secondary" class="space-y-4">
    {data.repoAnchors.map(anchor => (
      <div class="checkpoint-row">
        <span class="font-mono text-xs uppercase tracking-wider text-cyber-cyan/80 min-w-[7rem]">
          {friendlyAnchorLabel(anchor.label)}
        </span>
        <div class="min-w-0">
          <p class="text-sm text-slate-300 leading-snug truncate" title={anchor.repo}>{anchor.repo}</p>
          <p class="text-xs text-slate-500 leading-snug mt-0.5">{anchor.note}</p>
        </div>
        <SHAChip sha={anchor.sha} />
      </div>
    ))}
  </Card>
</Section>
