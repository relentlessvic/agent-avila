---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Project Progress Dashboard">
  <article class="glass-card max-w-2xl w-full p-8 sm:p-10">
    <h1 class="font-sans text-3xl sm:text-4xl text-slate-100 mb-2">
      Project Progress Dashboard
    </h1>
    <p class="font-mono text-sm text-cyber-cyan/80 mb-6">
      v1 — scaffold; content pending future phase
    </p>
    <p class="text-sm text-slate-400 leading-relaxed">
      This dashboard summarizes orchestrator state at build time. It is entirely
      separate from the trading runtime. Do not infer trading state from this UI.
    </p>
  </article>
</BaseLayout>
