---
import type { DashboardData } from '../../lib/types';
import Section from '../Section.astro';
import Card from '../Card.astro';
import SHAChip from '../SHAChip.astro';
import { formatGeneratedAt } from '../../lib/format';
import { SECTION_IDS } from '../../lib/constants';

interface Props {
  data: DashboardData;
}
const { data } = Astro.props;
const generatedDisplay = formatGeneratedAt(data.metadata.generatedAt);
---
<Section id={SECTION_IDS.header} title="My mission console">
  <Card tier="primary" class="sm:p-9">
    <h1 class="font-display font-semibold text-3xl sm:text-4xl text-slate-100 mb-1.5 tracking-tight">
      Project Progress Dashboard
    </h1>
    <p class="text-sm text-slate-400 mb-6 leading-relaxed">
      A calm console for what's done, what's on, what's locked, and what's next. Built for me, by me — nothing on this page can trade, deploy, or override me.
    </p>
    <div class="flex flex-wrap gap-x-4 gap-y-2 items-center text-xs font-mono text-slate-500">
      <span>Snapshot {generatedDisplay}</span>
      <span class="text-slate-700">·</span>
      <span class="inline-flex items-center gap-2" title="Parent project anchor">Parent <SHAChip sha={data.metadata.parentHead} /></span>
      <span class="text-slate-700">·</span>
      <span class="inline-flex items-center gap-2" title="Messenger project anchor">Messenger <SHAChip sha={data.metadata.relayHead} /></span>
    </div>
  </Card>
</Section>
