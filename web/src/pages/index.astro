---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadDashboard } from '../lib/load-dashboard';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import ActivePhase from '../components/sections/ActivePhase.astro';
import SafetyGates from '../components/sections/SafetyGates.astro';
import CompletedPhases from '../components/sections/CompletedPhases.astro';
import PausedPhases from '../components/sections/PausedPhases.astro';
import DesignedNotOpened from '../components/sections/DesignedNotOpened.astro';
import Backlog from '../components/sections/Backlog.astro';
import PhaseTimeline from '../components/sections/PhaseTimeline.astro';
import RepoAnchors from '../components/sections/RepoAnchors.astro';
import DormantVsActive from '../components/sections/DormantVsActive.astro';
import NextSafeAction from '../components/sections/NextSafeAction.astro';

const data = loadDashboard();
---
<BaseLayout title="Project Progress Dashboard">
  <div class="w-full pb-8">
    <Header data={data} />
    <Hero data={data} />
    <ActivePhase data={data} />
    <SafetyGates data={data} />
    <CompletedPhases data={data} />
    <PausedPhases data={data} />
    <DesignedNotOpened data={data} />
    <Backlog data={data} />
    <PhaseTimeline data={data} />
    <RepoAnchors data={data} />
    <DormantVsActive data={data} />
    <NextSafeAction data={data} />
  </div>
</BaseLayout>
