---
import type { DashboardData } from '../../lib/types';
import Section from '../Section.astro';
import Card from '../Card.astro';
import Pill from '../Pill.astro';
import { SECTION_IDS, getSafetyGateColor } from '../../lib/constants';

interface Props {
  data: DashboardData;
}
const { data } = Astro.props;
---
<Section id={SECTION_IDS.safetyGates} title="Safety Gates" icon="shield" count={data.safetyGates.length}>
  <Card>
    <table class="w-full">
      <thead class="text-xs font-mono uppercase tracking-wider text-slate-500">
        <tr>
          <th class="text-left pb-3 pr-4">Gate</th>
          <th class="text-left pb-3">Status</th>
        </tr>
      </thead>
      <tbody>
        {data.safetyGates.map(g => (
          <tr class="border-t border-slate-800/50">
            <td class="py-3 pr-4 text-sm text-slate-300 align-top">{g.name}</td>
            <td class="py-3 align-top">
              <Pill text={g.status} color={getSafetyGateColor(g.status)} />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </Card>
</Section>
