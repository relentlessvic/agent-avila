# Dashboard login credentials
DASHBOARD_EMAIL=your_email@example.com
DASHBOARD_PASSWORD=your_password_here

# Kraken API credentials
# Get these from: kraken.com → Security → API → Add Key
# Transfer/Withdrawal permissions: OFF. View + Trade: ON.
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET_KEY=your_private_key_here

# Trading mode: "spot" only (Kraken perpetuals vary by region)
TRADE_MODE=spot

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=1000

# Trade limits — these are your guardrails
MAX_TRADE_SIZE_USD=100        # No single trade can exceed this value
MAX_TRADES_PER_DAY=3          # Bot stops executing after this many trades in a calendar day

# Symbol and timeframe (symbol uses Binance format — bot maps to Kraken pairs automatically)
SYMBOL=BTCUSDT
TIMEFRAME=4H

# Set to "true" to run in paper trading mode (logs decisions but never places real orders)
PAPER_TRADING=true
